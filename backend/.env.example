# ContentSpy AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="ContentSpy AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=contentspy
DB_USERNAME=root
DB_PASSWORD=

# MongoDB (for spy snapshots)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=contentspy_spy

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Queue
QUEUE_CONNECTION=redis

# Authentication
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DRIVER=database

# Stripe
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# OpenAI
OPENAI_API_KEY=sk-xxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxx

# Replicate (Stable Diffusion)
REPLICATE_API_KEY=r8_xxx

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=xxx

# Google OAuth
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Resend (Email)
RESEND_API_KEY=re_xxx

# Sentry
SENTRY_DSN=

# R2 / S3 Storage
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=contentspy
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# Microservices
PLAYWRIGHT_SERVICE_URL=http://localhost:3001
FFMPEG_SERVICE_URL=http://localhost:3002

# Soketi (WebSocket)
SOKETI_HOST=127.0.0.1
SOKETI_PORT=6001

# Social Media OAuth - Facebook
FACEBOOK_CLIENT_ID=xxx
FACEBOOK_CLIENT_SECRET=xxx
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# Social Media OAuth - TikTok
TIKTOK_CLIENT_KEY=xxx
TIKTOK_CLIENT_SECRET=xxx
TIKTOK_REDIRECT_URI=http://localhost:8000/auth/tiktok/callback

# Social Media OAuth - Pinterest
PINTEREST_CLIENT_ID=xxx
PINTEREST_CLIENT_SECRET=xxx
PINTEREST_REDIRECT_URI=http://localhost:8000/auth/pinterest/callback